PORT=3000

# Projeto: https://supabase.com/dashboard/project/scpwlhfqlfkvudkkzvaf
SUPABASE_PROJECT_REF=scpwlhfqlfkvudkkzvaf
SUPABASE_URL=https://scpwlhfqlfkvudkkzvaf.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Copie estes valores para apps/api/.env (NUNCA coloque senha real aqui)
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_DB_HOST=aws-1-sa-east-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres.scpwlhfqlfkvudkkzvaf

# Ou URI completa (substitui as variáveis acima):
# DATABASE_URL=postgresql://postgres.scpwlhfqlfkvudkkzvaf:YOUR_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

REDIS_URL=redis://localhost:6379
DEFAULT_PRICING_REGION_ID=00000000-0000-4000-8000-000000000010
DEFAULT_SERVICE_REGION_ID=00000000-0000-4000-8000-000000000020
WEATHER_API_ENABLED=true
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRES_IN=7d
RIDE_CODE_SECRET=generate-a-long-random-ride-code-secret

# Mapbox (token público pk.* — obtenha em https://account.mapbox.com/access-tokens/)
MAPBOX_ACCESS_TOKEN=your-mapbox-public-token
MAPBOX_DEFAULT_LAT=-26.9194
MAPBOX_DEFAULT_LNG=-49.0661

# PSP / PIX (demo = sem gateway externo; http = PSP REST configurável)
PSP_PROVIDER=demo
PSP_API_URL=
PSP_API_SECRET=
PSP_WEBHOOK_SECRET=

# PSP real (escolha um via PSP_PROVIDER)
# PSP_PROVIDER=demo | stripe | mercadopago | pagarme | http
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
PAGARME_API_KEY=

# Match espacial PostGIS (true quando BD tem extensão postgis)
MATCH_USE_POSTGIS=true

# Push notifications (demo = log only; fcm = Firebase Cloud Messaging)
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_PROVIDER=demo
FCM_SERVER_KEY=

# Painel admin (header X-Admin-Key)
ADMIN_API_KEY=generate-a-long-admin-key
